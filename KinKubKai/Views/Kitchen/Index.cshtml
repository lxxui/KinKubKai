@model List<KinKubKai.Models.Order>
@{
    ViewData["Title"] = "กินกับไก่ - รายการอาหารของคุณ";
    Layout = null;
}
<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Kanit:wght@400;500;700;800&display=swap" rel="stylesheet">
    <style>
            :root {
                --bg: #f9f9f9;
                --card: #ffffff;
                --line: #f0e9e4;
                --text: #2b2523;
                --text-soft: #8a7e7a;
                --k-red: #d93829; /* แดงเกาหลีสดใส */
                --k-red-light: #fdf1f0; /* แดงอ่อนสำหรับไฮไลท์ */
                --k-yellow: #fecb2f; /* เหลืองมัสตาร์ดตัดโทน */
                --shadow: 0 4px 16px rgba(217, 56, 41, 0.06);
            }

            * {
                box-sizing: border-box;
            }

            body {
                margin: 0;
                background: var(--bg);
                color: var(--text);
                font-family: 'Kanit', sans-serif;
                padding: 20px;
            }

            .kt-container {
                max-width: 600px;
                margin: 0 auto;
            }

            .kt-header {
                text-align: center;
                margin-bottom: 25px;
                padding: 15px 0;
            }

            .kt-brand {
                font-size: 28px;
                font-weight: 800;
                color: var(--k-red);
                margin: 0 0 5px 0;
                display: flex;
                align-items: center;
                justify-content: center;
                gap: 8px;
            }

                .kt-brand span {
                    background: var(--k-yellow);
                    color: #000;
                    padding: 2px 10px;
                    border-radius: 20px;
                    font-size: 14px;
                    font-weight: 700;
                    vertical-align: middle;
                }

            .kt-header .kt-count {
                font-size: 14px;
                color: var(--text-soft);
                background: #fff;
                padding: 6px 16px;
                border-radius: 30px;
                display: inline-block;
                border: 1px solid var(--line);
                margin-top: 5px;
            }

            .kt-grid {
                display: flex;
                flex-direction: column;
                gap: 16px;
            }

            .kt-card {
                background: var(--card);
                border: 1px solid var(--line);
                border-radius: 16px;
                padding: 20px;
                box-shadow: var(--shadow);
                position: relative;
                overflow: hidden;
            }

                /* ตกแต่งแถบสีแดงด้านข้างการ์ดสไตล์เกาหลี */
                .kt-card::before {
                    content: '';
                    position: absolute;
                    left: 0;
                    top: 0;
                    bottom: 0;
                    width: 5px;
                    background: var(--k-red);
                }

            .kt-card-head {
                display: flex;
                align-items: center;
                justify-content: space-between;
                margin-bottom: 12px;
                padding-bottom: 12px;
                border-bottom: 2px dashed var(--line);
            }

            .kt-table {
                font-size: 20px;
                font-weight: 700;
                color: var(--text);
            }

            .kt-time {
                font-size: 13px;
                color: var(--text-soft);
                background: #f3f3f3;
                padding: 4px 10px;
                border-radius: 8px;
            }

            .kt-items {
                list-style: none;
                margin: 0 0 16px;
                padding: 0;
            }

                .kt-items li {
                    display: flex;
                    justify-content: space-between;
                    align-items: center;
                    font-size: 16px;
                    padding: 8px 0;
                    border-bottom: 1px solid #fafafa;
                }

            .kt-item-main {
                display: flex;
                align-items: center;
            }

            .kt-qty {
                background: var(--k-red-light);
                color: var(--k-red);
                font-weight: 700;
                font-size: 14px;
                padding: 2px 8px;
                border-radius: 6px;
                margin-right: 10px;
                min-width: 32px;
                text-align: center;
            }

            .kt-done-btn {
                width: 100%;
                padding: 12px;
                border-radius: 10px;
                border: none;
                background: var(--k-red);
                color: #fff;
                font-family: 'Kanit', sans-serif;
                font-weight: 700;
                font-size: 15px;
                cursor: pointer;
                transition: background 0.2s;
                box-shadow: 0 4px 12px rgba(217, 56, 41, 0.2);
            }

                .kt-done-btn:hover {
                    background: #b82d20;
                }

            .kt-empty {
                text-align: center;
                padding: 60px 20px;
                color: var(--text-soft);
                font-size: 16px;
                background: #fff;
                border-radius: 16px;
                border: 1px solid var(--line);
            }

            .kt-empty-icon {
                font-size: 40px;
                margin-bottom: 10px;
                display: block;
            }
    </style>
</head>
<body>

    <div class="kt-container">
        <div class="kt-header">
            <h1 class="kt-brand">🍗 กินกับไก่ <span>Kin Kub Kai</span></h1>
            <span class="kt-count">รายการอาหารที่สั่งไว้ (@Model.Count ออเดอร์)</span>
        </div>

        @if (!Model.Any())
        {
            <div class="kt-empty">
                <span class="kt-empty-icon">🍳</span>
                คุณยังไม่มีรายการอาหารที่สั่งในขณะนี้
            </div>
        }
        else
        {
            <div class="kt-grid">
                @foreach (var order in Model)
                {
                    var minutesAgo = (int)(DateTime.Now - order.CreatedAt).TotalMinutes;

                    <div class="kt-card">
                        <div class="kt-card-head">
                            <span class="kt-table">โต๊ะ @order.TableNumber</span>
                            <span class="kt-time">
                                @(minutesAgo <= 0 ? "เมื่อครู่นี้" : $"{minutesAgo} นาทีที่แล้ว")
                            </span>
                        </div>

                        <ul class="kt-items">
                            @foreach (var item in order.Items)
                            {
                                <li>
                                    <div class="kt-item-main">
                                        <span class="kt-qty">x@item.Quantity</span>
                                        <span>@item.Name</span>
                                    </div>
                                </li>
                            }
                        </ul>

                        <!-- ปุ่มสำหรับฝั่งลูกค้าตรวจสอบสถานะ หรือกดยืนยันเพิ่มเติม -->
                        <form method="post" action="/Kitchen/MarkDone/@order.Id">
                            <button type="submit" class="kt-done-btn">ตรวจสอบรายการอาหาร</button>
                        </form>
                    </div>
                }
            </div>
        }
    </div>

</body>
</html>